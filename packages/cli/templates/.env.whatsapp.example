# WhatsApp Cloud API webhook settings
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=replace-with-your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-your-whatsapp-phone-number-id
WHATSAPP_APP_SECRET=replace-with-your-meta-app-secret

# ClientPad public API settings
CLIENTPAD_PUBLIC_API_BASE_URL=http://localhost:3000
CLIENTPAD_API_KEY=replace-with-your-clientpad-api-key

# Optional payment provider secrets used by starter flows
PAYSTACK_SECRET_KEY=replace-with-your-paystack-secret-key
FLUTTERWAVE_SECRET_KEY=replace-with-your-flutterwave-secret-key

# Used when local phone numbers need normalization before API calls
DEFAULT_COUNTRY_CODE=+234
