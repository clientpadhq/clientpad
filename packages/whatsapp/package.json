{
  "name": "@clientpad/whatsapp",
  "version": "0.2.0",
  "description": "WhatsApp webhook handler, AI assistant, and Nigerian payment utilities for ClientPad.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "import": "./dist/payments.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "clientpad",
    "whatsapp",
    "webhook",
    "ai-assistant",
    "payments",
    "paystack",
    "flutterwave",
    "nigeria",
    "meta",
    "cloud-api",
    "typescript"
  ],
  "scripts": {
    "build": "pnpm --filter @clientpad/core build && pnpm --filter @clientpad/sdk build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @clientpad/core build && pnpm --filter @clientpad/sdk build && tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node test/whatsapp.test.mjs",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@clientpad/core": "workspace:*",
    "@clientpad/sdk": "workspace:*",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
