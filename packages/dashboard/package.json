{
  "name": "@abdulmuiz44/clientpad-dashboard",
  "version": "0.2.0",
  "description": "ClientPad Cloud developer dashboard for projects, API keys, usage, billing, and docs.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.html",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "typescript": "^5.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
